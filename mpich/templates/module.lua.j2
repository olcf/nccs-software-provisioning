{{ ansible_managed | comment(beginning='--[[', end=']]--', decoration='', prefix_count=0, postfix_count=0) }}

add_property("state", "experimental")

family("mpi")

depends_on("rocm", "libfabric")

if mode() == "load then
    LmodMessage("This module was built with rocm/{{ NSP_MPICH_rocm_version }}. It is possible to use this module with a different ROCm version but it is not supported!")
    LmodMessage("This module was built with libfabric/{{ NSP_MPICH_ofi_version }}. It is possible to use this module with a different Libfabric version but it is not supported!")
end

whatis("MPICH MPI implementation v{{ NSP_MPICH_version }}")

help("MPICH MPI implementation v{{ NSP_MPICH_version }}")

local base = "{{ NSP_install_root }}"
local package = "mpich"
local version = "{{ NSP_MPICH_version }}"
local prefix = pathJoin(base, package, version)

prepend_path("PATH", pathJoin(prefix, "bin"))
prepend_path("LIBRARY_PATH", pathJoin(prefix, "lib"))
prepend_path("LD_LIBRARY_PATH", pathJoin(prefix, "lib"))

setenv("MPIR_CVAR_ENABLE_GPU", "1")
setenv("MPIR_CVAR_CH4_OFI_ENABLE_HMEM", "1")
setenv("MPICH_ROOT", prefix)

setenv(string.upper("{{ NSP_site_name }}_") .. package:upper() .. "_ROOT",  prefix)
